# doongle-ai 워커 로컬 설정 예시.
# 복사해서 .env로 쓴다:  cp .env.example .env
# 비밀값(DATABASE_URL 등)은 .env에만 두고 git에 커밋하지 않는다.

# --- Kafka ---
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=image-upload
KAFKA_GROUP_ID=doongle-ai-workers

# --- PostgreSQL (doongle-api와 같은 DB) ---
DATABASE_URL=postgresql://doongle:doongle@localhost:5432/doongle

# --- 추론 모델 ---
MODEL=google/vit-base-patch16-224

# --- 스토리지 (local | minio) ---
STORAGE_BACKEND=local
# api와 같은 업로드 디렉터리를 가리켜야 한다(로컬 동일 머신 검증).
LOCAL_STORAGE_PATH=./uploads

# --- MinIO (STORAGE_BACKEND=minio 일 때 사용. 버킷은 콘솔에서 미리 생성, api와 같은 버킷) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=images
MINIO_SECURE=false
